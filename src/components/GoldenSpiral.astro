---
/*
 * Golden-section background animation (About page).
 * Act 1 — gold threads draw the golden-rectangle subdivisions, the two
 *         construction diagonals, then one continuous logarithmic spiral.
 * Act 2 — the camera dives toward the spiral's pole forever: the layer scales
 *         by φ² while rotating 180°, and because the figure is self-similar
 *         under exactly that transform, the end frame coincides with the
 *         start frame — a mathematically seamless infinite zoom.
 * Geometry is computed here at build time; strokes use non-scaling widths so
 * the loop point is invisible. Decorative only: fixed, z-index -1, md+ only.
 */

const PHI = (1 + Math.sqrt(5)) / 2;

// Recursive golden-rectangle subdivision inside a 1600x900 viewBox.
// The leftover rectangle spins clockwise (right, down, left, up), converging
// on the spiral's pole.
// Anchored right-of-center so the pole (the zoom focus) sits in the gutter
// beside the reading column rather than behind the text.
let cx = 560;
let cy = 140;
let cw = 1080;
let ch = 1080 / PHI;
const rectA = { x: cx, y: cy, w: cw, h: ch };
const squares: { x: number; y: number; s: number }[] = [];
let dir = 0;
for (let i = 0; i < 40; i++) {
	const s = Math.min(cw, ch);
	if (dir === 0) {
		if (i < 12) squares.push({ x: cx, y: cy, s });
		cx += s;
		cw -= s;
	} else if (dir === 1) {
		if (i < 12) squares.push({ x: cx, y: cy, s });
		cy += s;
		ch -= s;
	} else if (dir === 2) {
		if (i < 12) squares.push({ x: cx + cw - s, y: cy, s });
		cw -= s;
	} else {
		if (i < 12) squares.push({ x: cx, y: cy + ch - s, s });
		ch -= s;
	}
	dir = (dir + 1) % 4;
}
const pole = { x: cx + cw / 2, y: cy + ch / 2 };

const squarePaths = squares.map(
	(q) => `M ${q.x.toFixed(2)} ${q.y.toFixed(2)} h ${q.s.toFixed(2)} v ${q.s.toFixed(2)} h ${(-q.s).toFixed(2)} Z`
);

// Construction diagonals: the rectangle's diagonal and the reciprocal's,
// which intersect at the pole.
const s0 = squares[0].s;
const diagonals = [
	`M ${rectA.x} ${rectA.y} L ${rectA.x + rectA.w} ${rectA.y + rectA.h}`,
	`M ${rectA.x + rectA.w} ${rectA.y} L ${rectA.x + s0} ${rectA.y + rectA.h}`,
];

// One continuous logarithmic spiral around the pole: r shrinks by φ every
// quarter turn. Anchoring it to the first square's corner makes it pass
// through the matching corner of every deeper square (the corner orbit is the
// same self-similar transform the spiral follows), so thread and grid agree.
const b = Math.log(PHI) / (Math.PI / 2);
const anchor = { x: squares[0].x + squares[0].s, y: squares[0].y };
const r0 = Math.hypot(anchor.x - pole.x, anchor.y - pole.y);
const theta0 = Math.atan2(anchor.y - pole.y, anchor.x - pole.x);
const QUARTER = Math.PI / 2;
const spiralPoints: string[] = [];
for (let t = -2.5 * QUARTER; t <= 18 * QUARTER; t += Math.PI / 60) {
	const r = r0 * Math.exp(-b * t);
	const a = theta0 + t;
	spiralPoints.push(`${(pole.x + r * Math.cos(a)).toFixed(2)} ${(pole.y + r * Math.sin(a)).toFixed(2)}`);
}
const spiralPath = `M ${spiralPoints.join(' L ')}`;
---

<div class="phi-layer" aria-hidden="true">
	<svg viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
		<g class="phi-zoom" style={`transform-origin: ${pole.x.toFixed(2)}px ${pole.y.toFixed(2)}px`}>
			{diagonals.map((d, i) => (
				<path class="phi-diag" d={d} pathLength="1" vector-effect="non-scaling-stroke" style={`animation-delay: ${(2.6 + i * 0.3).toFixed(2)}s`} />
			))}
			{squarePaths.map((d, i) => (
				<path class="phi-rect" d={d} pathLength="1" vector-effect="non-scaling-stroke" style={`animation-delay: ${(i * 0.22).toFixed(2)}s`} />
			))}
			<path class="phi-spiral" d={spiralPath} pathLength="1" vector-effect="non-scaling-stroke" />
		</g>
	</svg>
</div>

<style is:global>
	.phi-layer {
		position: fixed;
		inset: 0;
		z-index: -1;
		display: none;
		pointer-events: none;
		user-select: none;
		opacity: 0.85;
	}

	@media (min-width: 768px) {
		.phi-layer {
			display: block;
		}
	}

	.phi-layer svg {
		width: 100%;
		height: 100%;
		display: block;
	}

	.phi-zoom {
		transform-box: view-box;
		animation: phi-zoom 30s linear 7s infinite;
	}

	.phi-rect,
	.phi-diag,
	.phi-spiral {
		fill: none;
		stroke-linecap: round;
		stroke-dasharray: 1;
		stroke-dashoffset: 1;
	}

	.phi-rect {
		stroke: rgba(180, 126, 36, 0.26);
		stroke-width: 1;
		animation: phi-draw 900ms cubic-bezier(0.45, 0, 0.3, 1) both;
	}

	.phi-diag {
		stroke: rgba(180, 126, 36, 0.16);
		stroke-width: 0.8;
		animation: phi-draw 1100ms cubic-bezier(0.45, 0, 0.3, 1) both;
	}

	.phi-spiral {
		stroke: rgba(170, 118, 32, 0.45);
		stroke-width: 1.6;
		animation: phi-draw 3200ms cubic-bezier(0.5, 0, 0.35, 1) 3.4s both;
	}

	html.dark .phi-rect {
		stroke: rgba(226, 190, 110, 0.2);
	}

	html.dark .phi-diag {
		stroke: rgba(226, 190, 110, 0.12);
	}

	html.dark .phi-spiral {
		stroke: rgba(226, 190, 110, 0.38);
	}

	@keyframes phi-draw {
		to {
			stroke-dashoffset: 0;
		}
	}

	/* φ² scale + half turn maps the figure onto itself: the loop never shows. */
	@keyframes phi-zoom {
		from {
			transform: scale(1) rotate(0deg);
		}
		to {
			transform: scale(2.618033988749895) rotate(180deg);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.phi-zoom {
			animation: none !important;
		}

		.phi-rect,
		.phi-diag,
		.phi-spiral {
			animation: none !important;
			stroke-dashoffset: 0 !important;
		}
	}
</style>
