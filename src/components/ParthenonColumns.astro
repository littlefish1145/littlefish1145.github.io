---
/*
 * Ionic colonnade sketch for the homepage side margins (xl viewports and up).
 * Architectural line-drawing style with a weight hierarchy: a T-shaped Ionic
 * capital (abacus + double spiral volutes with eyes + egg band), a fluted
 * tapered shaft, and a full base (apophyge, double torus, plinth) landing on
 * a ground line — the column visibly touches down instead of fading out.
 * Two columns per side, horizontally separated so strokes never overlap.
 */

// One Ionic column as stroke-only paths (viewBox 0 0 100 640).
// vector-effect keeps every weight constant no matter how the box is stretched.
const COLUMN_PATHS = `
	<!-- ===== Capital: gold fillet, abacus, double volutes, egg band ===== -->
	<path d="M20 4 H80" class="pc-line-gold" vector-effect="non-scaling-stroke" />
	<rect x="16" y="8" width="68" height="7" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M36 15 C16 15 6 24 6 36 C6 48 14 55 24 54 C32 53 36 46 32 40 C29 35 22 35 20 40 C19 44 22 47 25 46" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M64 15 C84 15 94 24 94 36 C94 48 86 55 76 54 C68 53 64 46 68 40 C71 35 78 35 80 40 C81 44 78 47 75 46" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M14 36 C14 44 19 49 25 48" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<path d="M86 36 C86 44 81 49 75 48" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<circle cx="24.5" cy="42.5" r="1.4" class="pc-eye" />
	<circle cx="75.5" cy="42.5" r="1.4" class="pc-eye" />
	<path d="M38 21 q3.5 7 7 0 M46.5 21 q3.5 7 7 0 M55 21 q3.5 7 7 0" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<path d="M33 57 H67" class="pc-line" vector-effect="non-scaling-stroke" />
	<!-- ===== Fluted, tapered shaft ===== -->
	<path d="M33 62 L29 562" class="pc-line-bold" vector-effect="non-scaling-stroke" />
	<path d="M67 62 L71 562" class="pc-line-bold" vector-effect="non-scaling-stroke" />
	<path d="M39.8 62 L37.4 562" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<path d="M46.6 62 L45.8 562" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<path d="M53.4 62 L54.2 562" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<path d="M60.2 62 L62.6 562" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<!-- ===== Base: apophyge and double torus settling straight onto the ground ===== -->
	<path d="M29 562 C29 574 25 580 19 582" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M71 562 C71 574 75 580 81 582" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M16 582 H84" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M16 582 C12 584 12 592 16 594" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M84 582 C88 584 88 592 84 594" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M16 594 H84" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M20 600 H80" class="pc-line pc-line-faint" vector-effect="non-scaling-stroke" />
	<path d="M12 606 H88" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M12 606 C8 608 8 616 12 618" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M88 606 C92 608 92 616 88 618" class="pc-line" vector-effect="non-scaling-stroke" />
	<path d="M12 618 H88" class="pc-line" vector-effect="non-scaling-stroke" />
	<!-- Ground line with a soft pooled shadow beneath -->
	<ellipse cx="50" cy="626" rx="52" ry="4.5" class="pc-ground-shadow" />
	<ellipse cx="50" cy="627" rx="64" ry="5.5" class="pc-ground-shadow pc-ground-shadow-wide" />
	<path d="M-8 621 H108" class="pc-line-bold" vector-effect="non-scaling-stroke" />
`;

// Gold pop-dots shimmering on the shaft (percent positions of the column box).
const nearSparks = [
	{ left: 46, top: 18, delay: '0s', dur: '4.1s' },
	{ left: 58, top: 30, delay: '1.4s', dur: '3.3s' },
	{ left: 38, top: 43, delay: '2.6s', dur: '4.6s' },
	{ left: 52, top: 56, delay: '0.8s', dur: '3.7s' },
	{ left: 61, top: 68, delay: '3.2s', dur: '4.2s' },
	{ left: 43, top: 79, delay: '1.9s', dur: '3.5s' },
];

const sides = ['left', 'right'];
---

{
	sides.map((side) => (
		<div class={`parthenon-grp parthenon-grp-${side}`} aria-hidden="true">
			<div class="pc-column pc-near">
				<svg viewBox="0 0 100 640" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" set:html={COLUMN_PATHS} />
				{nearSparks.map((s) => (
					<i class="pc-spark" style={`left:${s.left}%;top:${s.top}%;animation-delay:${s.delay};animation-duration:${s.dur}`} />
				))}
			</div>
			<div class="pc-column pc-far">
				<svg viewBox="0 0 100 640" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" set:html={COLUMN_PATHS} />
			</div>
		</div>
	))
}
