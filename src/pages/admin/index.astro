---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getAdminStats, getAdminComments, approveComment, rejectComment, deleteComment, type AdminComment } from '../../lib/admin';

let stats = { total: 0, pending: 0, approved: 0, rejected: 0 };
let comments: AdminComment[] = [];
let error = '';
let activeFilter = 'all';

const BASE = import.meta.env.BASE_URL;

// Handle form actions
if (Astro.request.method === 'POST') {
	const formData = await Astro.request.formData();
	const action = formData.get('action') as string;
	const id = formData.get('id') as string;

	if (!id) {
		error = 'Missing comment ID';
	} else {
		try {
			if (action === 'approve') {
				await approveComment(id);
			} else if (action === 'reject') {
				await rejectComment(id);
			} else if (action === 'delete') {
				await deleteComment(id);
			}
		} catch (e) {
			error = e instanceof Error ? e.message : 'Action failed';
		}
	}
}

// Handle filter
const url = new URL(Astro.request.url);
activeFilter = url.searchParams.get('status') || 'all';

// Initial data load
try {
	stats = await getAdminStats();
	const result = await getAdminComments(activeFilter === 'all' ? undefined : activeFilter);
	comments = result.comments;
} catch (e) {
	error = e instanceof Error ? e.message : 'Failed to load data';
}

function formatDate(ts: number): string {
	return new Date(ts).toLocaleString();
}

function truncateBody(body: string, maxLen = 80): string {
	return body.length > maxLen ? body.slice(0, maxLen) + '...' : body;
}

const statusColors: Record<string, string> = {
	pending: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',
	approved: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',
	rejected: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400',
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Admin - ${SITE_TITLE}`} description="Admin Dashboard" />
	</head>
	<body>
		<Header />
		<main class="page-shell page-fade-in py-10 md:py-14">
			<div class="mb-8">
				<h1 class="text-2xl font-semibold tracking-tight">Admin Dashboard</h1>
				<p class="mt-1 text-sm text-zinc-500">Comment moderation</p>
			</div>

			{error && (
				<div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-800 dark:bg-red-900/20 dark:text-red-400">
					{error}
				</div>
			)}

			{/* Stats Cards */}
			<div class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-4">
				<div class="rounded-xl border border-zinc-200 bg-white px-4 py-3 dark:border-zinc-700 dark:bg-zinc-900">
					<div class="text-sm font-medium text-zinc-500">Total</div>
					<div class="mt-1 text-2xl font-semibold">{stats.total}</div>
				</div>
				<div class="rounded-xl border border-yellow-200 bg-yellow-50 px-4 py-3 dark:border-yellow-800 dark:bg-yellow-900/20">
					<div class="text-sm font-medium text-yellow-700 dark:text-yellow-400">Pending</div>
					<div class="mt-1 text-2xl font-semibold text-yellow-600 dark:text-yellow-400">{stats.pending}</div>
				</div>
				<div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 dark:border-green-800 dark:bg-green-900/20">
					<div class="text-sm font-medium text-green-700 dark:text-green-400">Approved</div>
					<div class="mt-1 text-2xl font-semibold text-green-600 dark:text-green-400">{stats.approved}</div>
				</div>
				<div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 dark:border-red-800 dark:bg-red-900/20">
					<div class="text-sm font-medium text-red-700 dark:text-red-400">Rejected</div>
					<div class="mt-1 text-2xl font-semibold text-red-600 dark:text-red-400">{stats.rejected}</div>
				</div>
			</div>

			{/* Filter Tabs */}
			<div class="mb-4 flex gap-2">
				<a
					href={`${BASE}admin/`}
					class:list={[
						'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
						activeFilter === 'all'
							? 'bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900'
							: 'bg-zinc-100 text-zinc-600 hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700'
					]}
				>
					All
				</a>
				<a
					href={`${BASE}admin/?status=pending`}
					class:list={[
						'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
						activeFilter === 'pending'
							? 'bg-yellow-500 text-white'
							: 'bg-yellow-100 text-yellow-700 hover:bg-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-400 dark:hover:bg-yellow-900/50'
					]}
				>
					Pending
				</a>
				<a
					href={`${BASE}admin/?status=approved`}
					class:list={[
						'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
						activeFilter === 'approved'
							? 'bg-green-500 text-white'
							: 'bg-green-100 text-green-700 hover:bg-green-200 dark:bg-green-900/30 dark:text-green-400 dark:hover:bg-green-900/50'
					]}
				>
					Approved
				</a>
				<a
					href={`${BASE}admin/?status=rejected`}
					class:list={[
						'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
						activeFilter === 'rejected'
							? 'bg-red-500 text-white'
							: 'bg-red-100 text-red-700 hover:bg-red-200 dark:bg-red-900/30 dark:text-red-400 dark:hover:bg-red-900/50'
					]}
				>
					Rejected
				</a>
			</div>

			{/* Comments Table */}
			<div class="overflow-x-auto rounded-xl border border-zinc-200 dark:border-zinc-700">
				<table class="w-full text-sm">
					<thead class="bg-zinc-50 dark:bg-zinc-800/50">
						<tr>
							<th class="px-4 py-3 text-left font-medium text-zinc-500">Author</th>
							<th class="px-4 py-3 text-left font-medium text-zinc-500">Post</th>
							<th class="px-4 py-3 text-left font-medium text-zinc-500">Comment</th>
							<th class="px-4 py-3 text-left font-medium text-zinc-500">Status</th>
							<th class="px-4 py-3 text-left font-medium text-zinc-500">Date</th>
							<th class="px-4 py-3 text-right font-medium text-zinc-500">Actions</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-zinc-100 dark:divide-zinc-700/50">
						{comments.length === 0 ? (
							<tr>
								<td colspan="6" class="px-4 py-8 text-center text-zinc-400">No comments found</td>
							</tr>
						) : (
							comments.map(comment => (
								<tr class="hover:bg-zinc-50/50 dark:hover:bg-zinc-800/30">
									<td class="px-4 py-3">
										<div class="flex items-center gap-2">
											{comment.avatar_url ? (
												<img src={comment.avatar_url} alt="" class="h-6 w-6 rounded-full" />
											) : (
												<div class="flex h-6 w-6 items-center justify-center rounded-full bg-zinc-200 text-xs dark:bg-zinc-600">
													{comment.login?.[0]?.toUpperCase() || '?'}
												</div>
											)}
											<span class="font-medium">{comment.name || comment.login}</span>
										</div>
									</td>
									<td class="px-4 py-3 text-zinc-500">{comment.post_slug}</td>
									<td class="px-4 py-3 max-w-xs truncate" title={comment.body}>
										{truncateBody(comment.body)}
									</td>
									<td class="px-4 py-3">
										<span class={`inline-flex rounded-full px-2 py-0.5 text-xs font-medium ${statusColors[comment.status]}`}>
											{comment.status}
										</span>
									</td>
									<td class="px-4 py-3 text-zinc-400">{formatDate(comment.created_at)}</td>
									<td class="px-4 py-3">
										<div class="flex items-center justify-end gap-1">
											{comment.status === 'pending' && (
												<form method="post">
													<input type="hidden" name="action" value="approve" />
													<input type="hidden" name="id" value={comment.id} />
													<button
														type="submit"
														class="rounded-lg p-1.5 text-green-600 hover:bg-green-100 dark:hover:bg-green-900/30"
														title="Approve"
													>
														<svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
															<path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
														</svg>
													</button>
												</form>
											)}
											{comment.status === 'pending' && (
												<form method="post">
													<input type="hidden" name="action" value="reject" />
													<input type="hidden" name="id" value={comment.id} />
													<button
														type="submit"
														class="rounded-lg p-1.5 text-yellow-600 hover:bg-yellow-100 dark:hover:bg-yellow-900/30"
														title="Reject"
													>
														<svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
															<path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
														</svg>
													</button>
												</form>
											)}
											<form method="post">
												<input type="hidden" name="action" value="delete" />
												<input type="hidden" name="id" value={comment.id} />
												<button
													type="submit"
													class="rounded-lg p-1.5 text-red-600 hover:bg-red-100 dark:hover:bg-red-900/30"
													title="Delete"
													onclick="return confirm('Delete this comment?')"
												>
													<svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
														<path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.519.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd" />
													</svg>
												</button>
											</form>
										</div>
									</td>
								</tr>
							))
						)}
					</tbody>
				</table>
			</div>
		</main>
		<Footer />
	</body>
</html>
